int adjust_variable_idx;                  int RF_hold;int RF_release;int Laser_Vertical;int Laser_Horizontal;int laser_aasist_strong;int laser_aasist_motion;int LaserAssistTime;int LaserAssistSize;int LaserHeadShotStrength;int LaserHeadShotHoldTime;
                         
define AMOUNT_OF_VALNAME_IDX = 9; 

define MAX_MODS_COUNT = 7;                          

int modName_idx;  

  int LASERRAPIDFIRE_onoff = 0 ;  int LASERANTIRECOIL_onoff = 1 ;  int laser_aim_assist_onoff = 0 ;  int ToggleLASERSTICKYAIM = 0 ;  int HeadShotAssist_onoff = 0 ; 
  int USE_SILENT_AIM = 0 ;  int rumble_onoff = 0 ;  int VM_Speed = 0 ; 

  const string LASERRAPIDFIRE            = "RAPID FIRE" ; const string LASERANTIRECOIL           = "LASER RECOIL" ; const string LASERAIMASSIST       = "LASER AIM ASSIST" ; const string LASERSTICKYAIM       = "LASER ASSIST V2" ; 
  const string HEAD_SHOT_ASSIST     = "LASER HEADSHOT" ;  const string SILENT_AIM         = "SILENT AIM" ;  const string VIBRATIONSONOFF         = "VIBRATION" ;  const string VMSPEED              = "VM SPEED" ; 


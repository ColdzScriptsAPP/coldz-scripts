const string EditVarStr []={ 
"RF HOLDS", 
"RF RELEASE", 
"LR VERTICAL", 
"LR HORIZONTAL",
"LA STRONG", 
"LA MOTION", 
"LA TIME", 
"LA SIZE", 
"HS SRONG", 
"HS WAIT TIME"  
};
 
define TimeToShowIntroPicture = 30000;
  
init {  
LASERRAPIDFIRE_onoff        = get_pvar(SPVAR_1,1,3,0); 
LASERANTIRECOIL_onoff       = 1; 
laser_aim_assist_onoff = 1; 
ToggleLASERSTICKYAIM   = 1; 
HeadShotAssist_onoff   = get_pvar(SPVAR_5,0,1,0); 
USE_SILENT_AIM         = 1;
rumble_onoff           = get_pvar(SPVAR_7,0,1,0); 
VM_Speed               = get_pvar(SPVAR_8,1,5,5); 
RF_hold            = get_pvar(SPVAR_9, 1,1000, 20);
RF_release         = get_pvar(SPVAR_10, 1,1000, 30);
Laser_Vertical         = get_pvar(SPVAR_11, 1,99, 29);
Laser_Horizontal       = get_pvar(SPVAR_12, -99,99, 0);
laser_aasist_strong  = get_pvar(SPVAR_13, 1,99, 16);
laser_aasist_motion  = get_pvar(SPVAR_14, 1,99, 64);
LaserAssistTime      = get_pvar(SPVAR_15, 1,100, 30);
LaserAssistSize      = get_pvar(SPVAR_16, 1,100, 18);
LaserHeadShotStrength    = get_pvar(SPVAR_17, 1,99, 20);
LaserHeadShotHoldTime    = get_pvar(SPVAR_18, 1,2000, 800);

   slot_numb = get_slot();

}
main {
                                  
  
 if(get_ival(ADS_BTN)){
     if(event_press(PS4_SHARE)){
         EntireScript_OnOff    = !EntireScript_OnOff;
         blinck(EntireScript_OnOff);
         cls_oled(0);
         draw_rectangle();
        
         display_mod( center_x(sizeof(SCRIPT_ONOFF)- 1, OLED_FONT_MEDIUM_WIDTH) ,SCRIPT_ONOFF [0],EntireScript_OnOff ,1);
         show_mesage_time = 2000;
 		    
 		 if(!EntireScript_OnOff) set_Virtual_Machine_Speed(VM_Default); 
     }
 }
                          
 if(show_mesage_time){
     show_mesage_time -= get_rtime();
     if(show_mesage_time <= 0) {
         cls_oled(0);    
     }
 }
                               

 if(EntireScript_OnOff){
                      
	if(ModEdit || ModMenu) set_Virtual_Machine_Speed(VM_Default);
    if(display_EDIT){                
    	        
        cls_oled(0);                        
        
		if(EditVal[ modName_idx ] == 0 ){  
			                
		    line_oled(1,45,127,45,1,0);    
		    print( center_x( 17, OLED_FONT_SMALL_WIDTH ), 20, OLED_FONT_SMALL, 1, NO_EDIT_VAR1[0] ); 
		    print( center_x( 12, OLED_FONT_SMALL_WIDTH ), 33, OLED_FONT_SMALL, 1, NO_EDIT_VAR2[0] ); 
		}                                                                                            
		else {
          display_edit( adjust_variable_idx [adjust_variable_idx + 1]);
          adjust_variable_idx [adjust_variable_idx + 1] = edit_val(adjust_variable_idx [adjust_variable_idx + 1] );
		}
   }
    if(refresh_OLED)
    { 
         
        cls_oled(0);       
                           
        
        draw_rectangle(); 
        
        if(modName_idx == 0)display_mod( center_x(sizeof(LASERRAPIDFIRE)- 1, OLED_FONT_SMALL_WIDTH ) ,LASERRAPIDFIRE[0],LASERRAPIDFIRE_onoff,Options[ modName_idx ]);
        if(modName_idx == 1)display_mod( center_x(sizeof(LASERANTIRECOIL)- 1, OLED_FONT_SMALL_WIDTH ) ,LASERANTIRECOIL[0],LASERANTIRECOIL_onoff,Options[ modName_idx ]);
        if(modName_idx == 2)display_mod( center_x(sizeof(LASERAIMASSIST)- 1, OLED_FONT_SMALL_WIDTH ) ,LASERAIMASSIST[0],laser_aim_assist_onoff,Options[ modName_idx ]);
        if(modName_idx == 3)display_mod( center_x(sizeof(LASERSTICKYAIM)- 1, OLED_FONT_SMALL_WIDTH ) ,LASERSTICKYAIM[0],ToggleLASERSTICKYAIM,Options[ modName_idx ]);
        if(modName_idx == 4)display_mod( center_x(sizeof(HEAD_SHOT_ASSIST)- 1, OLED_FONT_SMALL_WIDTH ) ,HEAD_SHOT_ASSIST[0],HeadShotAssist_onoff,Options[ modName_idx ]);
        if(modName_idx == 5)display_mod( center_x(sizeof(SILENT_AIM)- 1, OLED_FONT_SMALL_WIDTH ) ,SILENT_AIM[0],USE_SILENT_AIM,Options[ modName_idx ]);
        if(modName_idx == 6)display_mod( center_x(sizeof(VIBRATIONSONOFF)- 1, OLED_FONT_SMALL_WIDTH ) ,VIBRATIONSONOFF[0],rumble_onoff,Options[ modName_idx ]);
        if(modName_idx == 7)display_mod( center_x(sizeof(VMSPEED)- 1, OLED_FONT_SMALL_WIDTH ) ,VMSPEED[0],VM_Speed,Options[ modName_idx ]);
              
         refresh_OLED = FALSE; 
    } 
    if(display_title){           
             
    	     cls_oled(0);            
    	     print(center_x(sizeof(TITLE) - 1, OLED_FONT_MEDIUM_WIDTH),13,OLED_FONT_MEDIUM,OLED_WHITE,TITLE[0]);
	                  
	         ModMenu = FALSE;   
           display_title = FALSE;  
           display_black = TRUE;
                                   
    }                            
      
      
    if(display_black )         
    {                            
        count_black += get_rtime();
        if(count_black >= TimeToShowIntroPicture)   
        {                        
            cls_oled(0);         
            count_black = 0;      
            display_black = FALSE; 
        }                         
    }                           
                                
               
   if(ModEdit){ 
        block_all_inputs(); 
        if(MenuTimeOut){
            CheckIfBtnIsPressed();
        } 
        
       if(event_release(PS4_CIRCLE)){
             ModEdit      = FALSE;           
             display_EDIT = FALSE;           
             ModMenu      = TRUE;            
             refresh_OLED = TRUE;   
       }                    
                                                                             
        if(!get_ival(ADS_BTN) && event_press(PS4_DOWN)){            
                                          
        	   adjust_variable_idx ++;                 
        	   if(adjust_variable_idx > OptRange[ modName_idx ][ 1 ])  adjust_variable_idx = OptRange[ modName_idx ][ 1 ]; 
             refresh_OLED = FALSE;      
             display_EDIT = TRUE;        
        }          
                                                                            
        if(!get_ival(ADS_BTN) && event_press(PS4_UP)){  
                                                               
        	   adjust_variable_idx --;                                      
        	   if(adjust_variable_idx < OptRange[ modName_idx ][ 0 ]) adjust_variable_idx = OptRange[ modName_idx ][ 0 ];
             refresh_OLED = FALSE;      
             display_EDIT = TRUE;        
        }                                                           
            
        if(MenuTimeOut){
            CheckIfBtnIsPressed();
        }
   }           
   if(get_ival(ADS_BTN) && event_press(PS4_OPTIONS)){  
        ModMenu = TRUE;  
                             
                 modName_idx  = 0;                   
                 refresh_OLED = TRUE;       
                 display_EDIT = FALSE;        
                 MenuTimeOut  = menu_time_active;
   }      
               
   if(ModMenu){  
        block_all_inputs(); 
      
      if(event_press(PS4_CIRCLE)){
          ModMenu = FALSE;                     
          ModEdit = FALSE;              
          combo_run(MESSAGE);             
      }                    
     
      if(event_press(PS4_CROSS)){
          ModMenu             = FALSE;   
          adjust_variable_idx = OptRange[ modName_idx ][ 0 ]; 
          ModEdit             = TRUE;   
          display_EDIT        = TRUE; 
      }                    
                                  
                            
        if( !get_ival(ADS_BTN) && event_press(PS4_DOWN)){ 
                                          
        	   modName_idx ++;                 
        	   if(modName_idx > MAX_MODS_COUNT) modName_idx = 0; 
            
        	   blinck( modName_idx[modName_idx + 1]); 
             
        }                          
        if(!get_ival(ADS_BTN) && event_press(PS4_UP)){  
                                                               
        	  modName_idx --;                                      
        	  if(modName_idx < 0) modName_idx = MAX_MODS_COUNT;
           
        	   blinck( modName_idx[modName_idx + 1]); 
             
          }                        
        	
                                  
                    
        display_black = FALSE;    
        display_title = FALSE;    
       
        if(!get_ival(ADS_BTN) ){    
             if(event_press(PS4_RIGHT)){ 
                 modName_idx[modName_idx + 1] = f_go_back( modName_idx[modName_idx + 1] ); 
             } 
             if(event_press(PS4_LEFT)){
                 modName_idx[modName_idx + 1] = f_go_forward( modName_idx[modName_idx + 1] );
             }
       } 
        refresh_OLED = TRUE;   
        set_val(PS4_RIGHT,0); 
        set_val(PS4_LEFT,0); 
        set_val(PS4_UP,0); 
        set_val(PS4_DOWN,0); 
        if(MenuTimeOut){
            CheckIfBtnIsPressed();
        }
    } 
    
   if(!ModEdit && !ModMenu){
                    
             combo_run(Blink_MOD_ON);          
              
             set_Virtual_Machine_Speed (VM_Speed);
                                                   
        
        if(LASERRAPIDFIRE_onoff) { 
            if(get_ival(PS4_L2) && event_press(PS4_RIGHT)){   
                 KS_LASERRAPIDFIRE = !KS_LASERRAPIDFIRE;          
                 set_rumble_tipe(LASERRAPIDFIRE_onoff); 
                 display_MOD_status(KS_LASERRAPIDFIRE,sizeof(LASERRAPIDFIRE)- 1,LASERRAPIDFIRE[0]);
                 set_val(PS4_RIGHT,0);
            }               
        }               
        if(LASERRAPIDFIRE_onoff && KS_LASERRAPIDFIRE ) { 
          
            if ((LASERRAPIDFIRE_onoff == 2 && get_ival(ADS_BTN) && get_ival(FIRE_BTN)) || (LASERRAPIDFIRE_onoff == 1 && get_ival(FIRE_BTN) && !get_ival(ADS_BTN)) || (LASERRAPIDFIRE_onoff == 3 && get_ival(FIRE_BTN))) {
                 combo_run(RAPID_FIRE_cmb);         
            }                                       
         
        }                                   
                                         
            
            if(!rumble_onoff)
                block_rumble();
                                
		    
     if(LASERANTIRECOIL_onoff && KS_anti_recoil){                               
    	    if( get_ival(ADS_BTN) && get_ival(FIRE_BTN )) {      
    	        combo_run(LASERANTIRECOIL);                 
    	    }                                          
                                                           
    	    if( abs(get_ival(RY)) > AR_Release || abs(get_ival(RX)) > AR_Release) { 
    	        combo_stop (LASERANTIRECOIL);               
    	    }                                
             
            if(get_ival(PS4_R3)){
                if(event_press(PS4_UP)){
                    Laser_Vertical += 1;
                }
                if(event_press(PS4_DOWN)) {
                    Laser_Vertical -= 1;
                }
                set_val(PS4_UP,0); set_val(PS4_DOWN,0);
                                                       
                if(event_press(PS4_LEFT)){
                    Laser_Horizontal -= 1;
                }
                if(event_press(PS4_RIGHT)) {
                    Laser_Horizontal +=  1;
                }
                set_val(PS4_LEFT,0); set_val(PS4_RIGHT,0);
                                                                
             
               if(event_press(PS4_PS)){
                    combo_run(MESSAGE);       
               }
               set_val(PS4_PS,0);
           }
                                                  
     }
            if(HeadShotAssist_onoff ) {
                RY_analog = LaserHeadShotStrength * -1;
                if(get_ival(FIRE_BTN) && get_ptime(FIRE_BTN) < LaserHeadShotHoldTime) {     
                    offset_analog(RY,RY_analog);    
                }
            }         
		 
  if(laser_aim_assist_onoff){
                         
      actual_X = get_ival(X);   
      actual_Y = get_ival(Y);           
      actual_Magnitude = isqrt(pow(actual_X, 2) + pow(actual_Y, 2));  
      max_Magnitude = (actual_Magnitude < 100);                      
                                                                  
      if(!(time++ % STEP_INTERVAL)){                                  
	         angle += laser_aasist_motion;                                                 
      }                                                               
      angle = angle % 360;                                            
      sin_angle_dnatme = Polar_Array[angle % 360];                           
      cos_angle_dnatme = Polar_Array[(angle + 270) % 360];                  
      cos_angle_dnatme = (cos_angle_dnatme * laser_aasist_strong) / 100;                         
      sin_angle_dnatme = (sin_angle_dnatme * laser_aasist_strong) / 100;                          
                                                                         
      if((ACTIVE_WHEN_ADS && get_ival(ADS_BTN)) || (ACTIVE_WHEN_FIRING && get_ival(FIRE_BTN))){ 
           if(actual_Magnitude <= laser_aasist_strong){                                                      
                sin_angle_dnatme -= actual_Y;                                                              
                cos_angle_dnatme -= actual_X;                                                                 
           }else {                                                                                       
                sin_angle_dnatme = (sin_angle_dnatme * (200 - ((abs(actual_Y) + actual_Magnitude) / 10) * 10) / 200) * max_Magnitude; 
                cos_angle_dnatme = (cos_angle_dnatme * (200 - ((abs(actual_X) + actual_Magnitude) / 10) * 10) / 200) * max_Magnitude; 
           }                                                  
           set_val(X, calculate(actual_X + cos_angle_dnatme, -100, 100));
           set_val(Y, calculate(actual_Y + sin_angle_dnatme, -100, 100)); 
      } 
  } 
                                                  
            if(time_to_clear_screen){               
                time_to_clear_screen -= get_rtime();
                if(time_to_clear_screen <= 0 ){     
                    QT_MESSAGE_TIMEOUT();     
                }                              
            }            
                          
           
            if(ToggleLASERSTICKYAIM){
                if(get_ival(FIRE_BTN))
                    combo_run(StickyAim);
            }

            
            if(USE_SILENT_AIM)
            {                                 
                 deadzone(PS4_L2,PS4_R2,99,99);
            }                                 

        } 
    } 
} 
const int16 ValRange [][] ={
{ 1,1000 }, // RF_hold
{ 1,1000 }, // RF_release
{ 1,99 }, // Laser_Vertical
{ -99,99 }, // Laser_Horizontal
{ 1,99 }, // laser_aasist_strong
{ 1,99 }, // laser_aasist_motion
{ 1,100 }, // LaserAssistTime
{ 1,100 }, // LaserAssistSize
{ 1,99 }, // LaserHeadShotStrength
{ 1,2000 }  // LaserHeadShotHoldTime
};       
       

define VM_Default = 0;
function set_Virtual_Machine_Speed (f_speed){
    if     (f_speed == 0) vm_tctrl(-0);//10 ms Default
    else if(f_speed == 1) vm_tctrl(-2);// 8 ms
    else if(f_speed == 2) vm_tctrl(-4);// 6 ms
    else if(f_speed == 3) vm_tctrl(-6);// 4 ms
    else if(f_speed == 4) vm_tctrl(-8);// 2 ms
    else if(f_speed == 5) vm_tctrl(-9);// 1 ms
}
           
int primary_weapon = TRUE;
int message_timeout;
int time_to_clear_screen;
function QT_MESSAGE_TIMEOUT (){     
	              
	cls_oled(0);   
	display_title  = FALSE;           
}                                  
                                      
                       
int exit_wait = 1500;
combo EXIT {     
	wait(exit_wait);     
	cls_oled(0);    
	ModMenu = FALSE;  
	ModEdit = FALSE;    
	display_EDIT  = FALSE; 
	display_title = TRUE; 
}                      
int LED_OnOff;       
int rumble_tipe = RUMBLE_A;

combo LED_BLINK {                                 
	colourled(LED_OnOff);                           
	wait(200);                                      
	colourled(ColorOFF);                            
	wait(100);                                      
	colourled(LED_OnOff);                           
	wait(200);                                      
	colourled(ColorOFF);                             
	wait(100);                                      
}                                                 

int profile_numbr;                                
combo PROFILES_VIBRATE_NOTIFY {                    
    if(profile_numbr >= 1) set_rumble(rumble_tipe, 100);
    wait(300);                                       
    reset_rumble();                                   
    wait(100);                                       
    if(profile_numbr > 1)set_rumble(rumble_tipe, 100);
    wait(300);                                       
    reset_rumble();                                  
    wait(100);                                       
    if(profile_numbr > 2)set_rumble(rumble_tipe, 100);
    wait(300);                                       
    reset_rumble();                                 
}
define PRIMARY_Profile   = 1;
define SECONDARY_Profile = 2;
function set_profile_notify(f_profile,rumbl_type){
    profile_numbr = f_profile;
    rumble_tipe   = rumbl_type;
    combo_run(PROFILES_VIBRATE_NOTIFY);
}


combo vibrate {                                   
	set_rumble(rumble_tipe, 100);                   
	wait(300);                                       
	reset_rumble();                                 
	wait(100);                                       
	set_rumble(rumble_tipe, 100);                   
	wait(300);                                       
	reset_rumble();                                 
}                                                 

function set_rumble_tipe ( val) {                  
	if( val){ rumble_tipe = RUMBLE_A ; LED_OnOff = Green;}  
	else    { rumble_tipe = RUMBLE_B ; LED_OnOff = Red  ;} 
	combo_run(vibrate);                     
	combo_run(LED_BLINK);                   
}                                         
 
int b_dblclick;

function double_click (button) {                      
    if (b_dblclick) {                                 
        b_dblclick -=get_rtime();                                      
    }                                                 
    if (event_press(button) ) {
        if(b_dblclick){
            b_dblclick = 0;
            return TRUE;
        }else{
            b_dblclick = 300;
            return FALSE;
        }
    }                                                 
    return FALSE;                                        
}           


int flick_up_shooting_active = 1;
int delay_duration           = 820;
int fade_delay_duration      = 820;
int autoFade_tempo           = 820;
int stabilization_variation  = 34;
int is_turbo_fade            = 0;
int noDip_active             = 0;
int square_shooting_in_progress = 0;

int Insta_shot_active      = 1;
int Insta_shot_duration_L  = 8000;
int Delay_duration_Insta_L = 820;
int Insta_shot_duration_R  = 8000;
int Delay_duration_Insta_R = 820;

int goto_preset_index = 0;
int preset_val_L      = 0;
int preset_val_R      = 0;
int preset_0_L = -1;
int preset_0_R = -1;
int preset_1_L = -1;
int preset_1_R = -1;
int preset_2_L = -1;
int preset_2_R = -1;
int preset_3_L = -1;
int preset_3_R = -1;

int New_Insta_shot_active    = 1;
int New_Insta_shot_duration  = 2400;
int New_Insta_Delay_duration = 820;

int turbo_mode = 0;
int turbo_fade_L_timing = 4000;
int turbo_fade_L_tempo  = 820;
int turbo_fade_R_timing = 4000;
int turbo_fade_R_tempo  = 820;
int turbo_hop_L_timing  = 4000;
int turbo_hop_L_tempo   = 820;
int turbo_hop_R_timing  = 4000;
int turbo_hop_R_tempo   = 820;
int turbo_L_timing      = 4000;
int turbo_L_tempo       = 820;
int turbo_R_timing      = 4000;
int turbo_R_tempo       = 820;

int rs_shooting_active      = 0;
int rs_hold_duration        = 300;
int isHolding               = 0;
int holdTimer               = 0;
int rs_is_up                = 0;
int rs_shooting_in_progress = 0;

int remap_square_active = 2;
int infinite_stamina    = 0;
int ground_control      = 70;
int ground_stick_active = 1;
int meterDunkActive          = 0;
int meterDunkComboRunning    = 0;
int meterDunkOverrideActive  = 0;
int meterDunkStartTime       = 0;
int meterDunkDuration        = 1000;
int current_time             = 0;
int spotTakeMacro            = 0;
int zenColour                = 1;
int vibratorActive           = 0;

int rainbow_hue   = 0;
int rainbow_timer = 0;
int rainbow_r     = 255;
int rainbow_g     = 0;
int rainbow_b     = 0;
int rainbow_seg   = 0;
int rainbow_pos   = 0;

int STICK_DOWN_VALUE = 100;
int STICK_UP_VALUE   = -100;

int random_variation_min      = -7;
int random_variation_max      =  7;
int random_hold_variation_min = -2;
int random_hold_variation_max =  2;

int shot_display_active = 0;
int shot_display_timer  = 0;

int num_bubbles    = 20;
int bubble_x[20];
int bubble_y[20];
int bubble_speed[20];
int bubble_size[20];
int bubble_i;

int saver_on          = 0;
int saver_timer       = 0;
int sx = 2, sy = 2, svx = 1, svy = 1;
int msg_w, line1_w, line2_w, line3_w, line4_w;

int startup = 1, menu_enabled = 0, circle_exit_held = 0, page = 1;
int cur_cat  = 0;
int in_cat   = 0;
int cat_page = 0;
int menuSelection, toggleType, flashtoggle, isXbox, cat_max_page;

int isLoadingScreen  = 1;
define LoadingTimer  = 3000;
int LoadingTimeToRun = 0;
int spin_frame       = 0;
int spin_timer       = 0;
int loading_drawn    = 0;

int graph_width, x_start, mid_x, bar_pos;
int bufferIndex, digitIndex, charIndex;
int whole, frac, frac_tens, frac_ones;
int q_whole, q_frac;
int logVal, stringLength;

int scroll_hold_timer   = 0;
int scroll_repeat_timer = 0;
int scroll_held         = 0;
int scroll_fired        = 0;
define SCROLL_INITIAL_DELAY = 500;
define SCROLL_REPEAT_RATE   = 80;

int trans_active          = 0;
int trans_dir             = 1;
int trans_x               = 0;
int trans_pending_cat     = -1;
int trans_pending_incat   = -1;
int trans_pending_catpage = -1;
define TRANS_STEP = 22;
int slide_ox = 0;

int saved_version   = 0;
int current_version = 21;

const string welcome_text[]     = { "" };
const string saver_line1[]      = { "LT + OPT" };
const string saver_line2[]      = { "" };
const string saver_line3[]      = { "" };

const string menu_header[] = {
    "Button Tempo",
    "Setshot Tempo",
    "Fade Tempo",
    "No-Dip Tempo",
    "Stability Enhancer",
    "",
    "RS Shooting",
    "Goto Shot",
    "Goto Timing",
    "Goto Tempo",
    "Set Shots",
    "Set Shot Timing",
    "Set Shot Tempo",
    "Remap Square",
    "Infinite Stamina",
    "Meter Dunk",
    "Spot Take Macro",
    "Zen Colour",
    "Goto Presets",
    "Turbo Shots",
    "L Timing",
    "L Tempo",
    "R Timing",
    "R Tempo",
    "",
    "",
    "Vibrator"
};

const string cat_names[] = { "Button Tempo", "Go-to Shots", "Turbo Shots", "Set Shots", "Misc" };

const string turboModeNames[] = { "Turbo Fade", "Hop Jumper" };

const string turbo_L_header[] = {
    "L Fade Timing", "L Fade Tempo", "R Fade Timing", "R Fade Tempo",
    "L Hop Timing",  "L Hop Tempo",  "R Hop Timing",  "R Hop Tempo"
};

const string onOff[]        = { "OFF", "ON", "", "L3", "R3", "SQ" };
const string colourNames[]  = { "Red", "Green", "Blue", "Cyan", "Purple", "White", "Rainbow" };
const string ms[]           = { "ms" };
const string preset_names[] = { "Jalen", "Zac", "Jaden", "Tyrese" };
const string preset_L_str[] = { "L" };
const string preset_R_str[] = { "R" };
const string preset_saved_str[] = { "saved" };
const string preset_empty_str[] = { "unsaved" };

init {
    flick_up_shooting_active = get_pvar(SPVAR_16, 0, 1,    1);
    delay_duration           = get_pvar(SPVAR_17, 0, 6000, 820);
    fade_delay_duration      = get_pvar(SPVAR_30, 0, 6000, 820);
    autoFade_tempo           = get_pvar(SPVAR_4,  0, 6000, 820);
    stabilization_variation  = get_pvar(SPVAR_18, 10, 100, 65);

    rs_shooting_active = get_pvar(SPVAR_20, 0, 1, 0);

    Insta_shot_active      = get_pvar(SPVAR_21, 0, 1,      1);
    Insta_shot_duration_L  = get_pvar(SPVAR_22, 0, 20000,  8000);
    Delay_duration_Insta_L = get_pvar(SPVAR_23, 0, 6000,   820);
    Insta_shot_duration_R  = Insta_shot_duration_L;
    Delay_duration_Insta_R = Delay_duration_Insta_L;

    New_Insta_shot_active    = get_pvar(SPVAR_27, 0, 1,    1);
    New_Insta_shot_duration  = get_pvar(SPVAR_28, 0, 4000, 2400);
    New_Insta_Delay_duration = get_pvar(SPVAR_29, 0, 6000, 820);

    turbo_mode          = get_pvar(SPVAR_12, 0, 1,      0);
    turbo_fade_L_timing = get_pvar(SPVAR_13, 400, 20000, 4000);
    turbo_fade_L_tempo  = get_pvar(SPVAR_14, 0, 6000,   820);
    turbo_fade_R_timing = get_pvar(SPVAR_19, 400, 20000, 4000);
    turbo_fade_R_tempo  = get_pvar(SPVAR_31, 0, 6000,   820);
    turbo_hop_L_timing  = get_pvar(SPVAR_32, 400, 20000, 4000);
    turbo_hop_L_tempo   = get_pvar(SPVAR_33, 0, 6000,   820);
    turbo_hop_R_timing  = get_pvar(SPVAR_34, 400, 20000, 4000);
    turbo_hop_R_tempo   = get_pvar(SPVAR_35, 0, 6000,   820);
    if (turbo_mode == 0) {
        turbo_L_timing = turbo_fade_L_timing; turbo_L_tempo = turbo_fade_L_tempo;
        turbo_R_timing = turbo_fade_R_timing; turbo_R_tempo = turbo_fade_R_tempo;
    } else {
        turbo_L_timing = turbo_hop_L_timing;  turbo_L_tempo = turbo_hop_L_tempo;
        turbo_R_timing = turbo_hop_R_timing;  turbo_R_tempo = turbo_hop_R_tempo;
    }

    remap_square_active = get_pvar(SPVAR_24, 0, 2, 2);
    infinite_stamina    = get_pvar(SPVAR_25, 0, 1, 0);
    meterDunkActive     = get_pvar(SPVAR_26, 0, 1, 0);
    spotTakeMacro       = get_pvar(SPVAR_1,  0, 1, 0);
    zenColour           = get_pvar(SPVAR_5,  0, 6, 1);
    vibratorActive      = get_pvar(SPVAR_40, 0, 1, 0);

    saved_version = get_pvar(SPVAR_15, 0, 100, 0);
    if (saved_version != current_version) {
        preset_0_L = -1; set_pvar(SPVAR_2,  -1);
        preset_0_R = -1; set_pvar(SPVAR_3,  -1);
        preset_1_L = -1; set_pvar(SPVAR_6,  -1);
        preset_1_R = -1; set_pvar(SPVAR_7,  -1);
        preset_2_L = -1; set_pvar(SPVAR_8,  -1);
        preset_2_R = -1; set_pvar(SPVAR_9,  -1);
        preset_3_L = -1; set_pvar(SPVAR_10, -1);
        preset_3_R = -1; set_pvar(SPVAR_11, -1);
        set_pvar(SPVAR_15, current_version);
        goto_preset_index = 0;
        set_pvar(SPVAR_38, 0);
    } else {
        preset_0_L = get_pvar(SPVAR_2,  -1, 2000000000, -1);
        preset_0_R = get_pvar(SPVAR_3,  -1, 2000000000, -1);
        preset_1_L = get_pvar(SPVAR_6,  -1, 2000000000, -1);
        preset_1_R = get_pvar(SPVAR_7,  -1, 2000000000, -1);
        preset_2_L = get_pvar(SPVAR_8,  -1, 2000000000, -1);
        preset_2_R = get_pvar(SPVAR_9,  -1, 2000000000, -1);
        preset_3_L = get_pvar(SPVAR_10, -1, 2000000000, -1);
        preset_3_R = get_pvar(SPVAR_11, -1, 2000000000, -1);

        goto_preset_index = get_pvar(SPVAR_38, 0, 3, 0);

        ApplyPreset(goto_preset_index);
    }

    if (get_pvar(SPVAR_39, 0, 1, 0) == 0) {
        delay_duration           = 820; set_pvar(SPVAR_17, delay_duration);
        fade_delay_duration      = 820; set_pvar(SPVAR_30, fade_delay_duration);
        autoFade_tempo           = 820; set_pvar(SPVAR_4,  autoFade_tempo);
        Delay_duration_Insta_L   = 820; set_pvar(SPVAR_23, Delay_duration_Insta_L);
        Delay_duration_Insta_R   = 820;
        New_Insta_Delay_duration = 820; set_pvar(SPVAR_29, New_Insta_Delay_duration);
        turbo_fade_L_tempo       = 820; set_pvar(SPVAR_14, turbo_fade_L_tempo);
        turbo_fade_R_tempo       = 820; set_pvar(SPVAR_31, turbo_fade_R_tempo);
        turbo_hop_L_tempo        = 820; set_pvar(SPVAR_33, turbo_hop_L_tempo);
        turbo_hop_R_tempo        = 820; set_pvar(SPVAR_35, turbo_hop_R_tempo);
        Insta_shot_duration_L    = 8000; set_pvar(SPVAR_22, Insta_shot_duration_L);
        Insta_shot_duration_R    = 8000;
        New_Insta_shot_duration  = 2400; set_pvar(SPVAR_28, New_Insta_shot_duration);
        turbo_fade_L_timing      = 4000; set_pvar(SPVAR_13, turbo_fade_L_timing);
        turbo_fade_R_timing      = 4000; set_pvar(SPVAR_19, turbo_fade_R_timing);
        turbo_hop_L_timing       = 4000; set_pvar(SPVAR_32, turbo_hop_L_timing);
        turbo_hop_R_timing       = 4000; set_pvar(SPVAR_34, turbo_hop_R_timing);
        if (turbo_mode == 0) {
            turbo_L_timing = turbo_fade_L_timing; turbo_L_tempo = turbo_fade_L_tempo;
            turbo_R_timing = turbo_fade_R_timing; turbo_R_tempo = turbo_fade_R_tempo;
        } else {
            turbo_L_timing = turbo_hop_L_timing;  turbo_L_tempo = turbo_hop_L_tempo;
            turbo_R_timing = turbo_hop_R_timing;  turbo_R_tempo = turbo_hop_R_tempo;
        }
        set_pvar(SPVAR_39, 1);
    }

    for (bubble_i = 0; bubble_i < num_bubbles; bubble_i++) {
        bubble_x[bubble_i]     = random(2, 125);
        bubble_y[bubble_i]     = random(0, 63);
        bubble_speed[bubble_i] = random(1, 2);
        bubble_size[bubble_i]  = random(1, 3);
    }
}

main {
    if (get_console() == PIO_XB1) isXbox = 1;
    else isXbox = 0;

    if (startup && isLoadingScreen) {

    if (!loading_drawn) {
        cls_oled(OLED_BLACK);
        loading_drawn = 1;
    }

    LoadingTimeToRun += get_rtime();
    if (LoadingTimeToRun >= LoadingTimer) {
        cls_oled(OLED_BLACK);
        spin_frame       = 0;
        spin_timer       = 0;
        loading_drawn    = 0;
        isLoadingScreen  = 0;
        startup          = 0;
        saver_on         = 1;
        saver_timer      = 160;
    }

    } else {
        combo_run(Movement_Control);

        if (get_val(PS4_L2) && get_val(PS4_OPTIONS)) {
            menu_enabled = 1;
            page         = 1;
            cur_cat      = 0;
            in_cat       = 0;
            cat_page     = 0;
            combo_run(vibration_on);
            set_rgb(0, 0, 255);
        }

        if (event_press(PS4_CIRCLE) && menu_enabled && in_cat == 0) {
            menu_enabled     = 0;
            circle_exit_held = 1;
            combo_run(vibration_off);
            set_rgb(0, 255, 0);
            saver_on          = 1;
        }

        if (circle_exit_held) {
            set_val(PS4_CIRCLE, 0);
            if (event_release(PS4_CIRCLE)) {
                circle_exit_held = 0;
            }
        }

        if (menu_enabled) {
            cls_oled(OLED_BLACK);
            if (!trans_active) { slide_ox = 0; }

            if (in_cat == 0) {
                print(center_x(get_string_length(cat_names[cur_cat]), OLED_FONT_SMALL_WIDTH) + slide_ox, 28, OLED_FONT_SMALL, OLED_WHITE, cat_names[cur_cat]);

                if (event_press(PS4_RIGHT) && !trans_active && cur_cat < 4) {
                    combo_run(vibration_valchg); start_transition(1, cur_cat + 1, in_cat, 0);
                }
                if (event_press(PS4_LEFT) && !trans_active && cur_cat > 0) {
                    combo_run(vibration_valchg); start_transition(-1, cur_cat - 1, in_cat, 0);
                }
                if (event_press(PS4_CROSS) && !trans_active) {
                    combo_run(vibration_on);
                    start_transition(1, cur_cat, 1, 0);
                }
            }

            if (in_cat == 1) {

                if (cur_cat == 0) {
                    if      (cat_page == 0) page = 1;
                    else if (cat_page == 1) page = 2;
                    else if (cat_page == 2) page = 3;
                    else if (cat_page == 3) page = 4;
                    else if (cat_page == 4) page = 5;
                    if (cat_page > 4) cat_page = 4;
                    if (cat_page < 0) cat_page = 0;
                } else if (cur_cat == 1) {
                    if      (cat_page == 0) page = 8;
                    else if (cat_page == 1) page = 9;
                    else if (cat_page == 2) page = 10;
                    else if (cat_page == 3) page = 19;
                    if (cat_page > 3) cat_page = 3;
                    if (cat_page < 0) cat_page = 0;
                } else if (cur_cat == 2) {
                    if      (cat_page == 0) page = 20;
                    else if (cat_page == 1) page = 21;
                    else if (cat_page == 2) page = 22;
                    else if (cat_page == 3) page = 23;
                    else if (cat_page == 4) page = 24;
                    if (cat_page > 4) cat_page = 4;
                    if (cat_page < 0) cat_page = 0;
                } else if (cur_cat == 3) {
                    if      (cat_page == 0) page = 11;
                    else if (cat_page == 1) page = 12;
                    else if (cat_page == 2) page = 13;
                    if (cat_page > 2) cat_page = 2;
                    if (cat_page < 0) cat_page = 0;
                } else {
                    if      (cat_page == 0) page = 7;
                    else if (cat_page == 1) page = 14;
                    else if (cat_page == 2) page = 15;
                    else if (cat_page == 3) page = 16;
                    else if (cat_page == 4) page = 17;
                    else if (cat_page == 5) page = 18;
                    if (cat_page > 5) cat_page = 5;
                    if (cat_page < 0) cat_page = 0;
                }

                if (page >= 21 && page <= 24) {
                    print(center_x(get_string_length(turbo_L_header[turbo_mode * 4 + (page - 21)]), OLED_FONT_SMALL_WIDTH) + slide_ox, 4, OLED_FONT_SMALL, OLED_WHITE, turbo_L_header[turbo_mode * 4 + (page - 21)]);
                } else {
                    print(center_x(get_string_length(menu_header[page - 1]), OLED_FONT_SMALL_WIDTH) + slide_ox, 4, OLED_FONT_SMALL, OLED_WHITE, menu_header[page - 1]);
                }

                if (page == 14) {
                    print(center_x(get_string_length(onOff[remap_square_active + 3]), OLED_FONT_MEDIUM_WIDTH) + slide_ox, 28, OLED_FONT_MEDIUM, OLED_WHITE, onOff[remap_square_active + 3]);
                } else if (page == 18) {
                    print(center_x(get_string_length(colourNames[zenColour]), OLED_FONT_MEDIUM_WIDTH) + slide_ox, 28, OLED_FONT_MEDIUM, OLED_WHITE, colourNames[zenColour]);
                } else if (page == 20) {
                    print(center_x(get_string_length(turboModeNames[turbo_mode]), OLED_FONT_MEDIUM_WIDTH) + slide_ox, 28, OLED_FONT_MEDIUM, OLED_WHITE, turboModeNames[turbo_mode]);
                } else if (page != 2 && page != 3 && page != 4 && page != 5 &&
                           page != 9 && page != 10 && page != 12 && page != 13 &&
                           page != 19 && page != 21 && page != 22 && page != 23 && page != 24) {
                    print(center_x(get_string_length(onOff[menuSelection]), OLED_FONT_MEDIUM_WIDTH) + slide_ox, 28, OLED_FONT_MEDIUM, OLED_WHITE, onOff[menuSelection]);
                }

                if (event_press(PS4_CIRCLE) && !trans_active) {
                    set_val(PS4_CIRCLE, 0);
                    combo_run(vibration_valchg);
                    start_transition(-1, 0, 0, 0);
                }

                if (cur_cat == 0) { cat_max_page = 4; }
                else if (cur_cat == 1) { cat_max_page = 3; }
                else if (cur_cat == 2) { cat_max_page = 4; }
                else if (cur_cat == 3) { cat_max_page = 2; }
                else { cat_max_page = 5; }

                if (get_val(PS4_L2) && event_press(PS4_RIGHT) && !trans_active && cat_page < cat_max_page) {
                    combo_run(vibration_valchg);
                    start_transition(1, cur_cat, in_cat, cat_page + 1);
                }
                if (get_val(PS4_L2) && event_press(PS4_LEFT) && !trans_active && cat_page > 0) {
                    combo_run(vibration_valchg);
                    start_transition(-1, cur_cat, in_cat, cat_page - 1);
                }

                if (page == 2 || page == 3 || page == 4 || page == 5 ||
                    page == 9 || page == 10 || page == 12 || page == 13 ||
                    page == 21 || page == 22 || page == 23 || page == 24) {
                    if (get_val(PS4_UP)) {
                        if (scroll_held != 1) {
                            scroll_held         = 1;
                            scroll_hold_timer   = 0;
                            scroll_repeat_timer = 0;
                            scroll_fired        = 0;
                        }
                        scroll_hold_timer += get_rtime();
                        if (!scroll_fired && scroll_hold_timer >= SCROLL_INITIAL_DELAY) {
                            scroll_fired        = 1;
                            scroll_repeat_timer = 0;
                        }
                        if (scroll_fired) { scroll_repeat_timer += get_rtime(); }
                    } else if (get_val(PS4_DOWN)) {
                        if (scroll_held != -1) {
                            scroll_held         = -1;
                            scroll_hold_timer   = 0;
                            scroll_repeat_timer = 0;
                            scroll_fired        = 0;
                        }
                        scroll_hold_timer += get_rtime();
                        if (!scroll_fired && scroll_hold_timer >= SCROLL_INITIAL_DELAY) {
                            scroll_fired        = 1;
                            scroll_repeat_timer = 0;
                        }
                        if (scroll_fired) { scroll_repeat_timer += get_rtime(); }
                    } else {
                        scroll_held         = 0;
                        scroll_hold_timer   = 0;
                        scroll_repeat_timer = 0;
                        scroll_fired        = 0;
                    }
                }

                if (page == 1) {
                    menuSelection = flick_up_shooting_active;
                    toggleType    = 0;
                    if (get_val(PS4_L2) && event_press(PS4_UP)) {
                        flick_up_shooting_active = 1;
                        set_pvar(SPVAR_16, flick_up_shooting_active);
                        flashtoggle = 1; combo_run(vibration_valchg); combo_run(flashtog);
                    }
                    if (get_val(PS4_L2) && event_press(PS4_DOWN)) {
                        flick_up_shooting_active = 0;
                        set_pvar(SPVAR_16, flick_up_shooting_active);
                        flashtoggle = 0; combo_run(vibration_valchg); combo_run(flashtog);
                    }
                }

                if (page == 2) {
                    menuSelection = 2; toggleType = 0;
                    DecimalToString(delay_duration);
                    if (get_val(PS4_L2)) {
                        if (event_press(PS4_UP))   delay_duration += 200;
                        if (event_press(PS4_DOWN))  delay_duration -= 200;
                        if (scroll_fired && scroll_repeat_timer >= SCROLL_REPEAT_RATE) { delay_duration += scroll_held * 200; scroll_repeat_timer = 0; }
                    } else {
                        if (event_press(PS4_UP))   delay_duration += 1;
                        if (event_press(PS4_DOWN))  delay_duration -= 1;
                        if (scroll_fired && scroll_repeat_timer >= SCROLL_REPEAT_RATE) { delay_duration += scroll_held; scroll_repeat_timer = 0; }
                    }
                    if (event_press(PS4_UP) || event_press(PS4_DOWN) || (scroll_fired && scroll_repeat_timer == 0 && scroll_held != 0)) {
                        set_pvar(SPVAR_17, delay_duration); combo_run(vibration_valchg); combo_run(flashedit);
                    }
                    if (delay_duration > 6000) delay_duration = 6000;
                    if (delay_duration < 0)    delay_duration = 0;
                }

                if (page == 3) {
                    menuSelection = 2; toggleType = 0;
                    DecimalToString(fade_delay_duration);
                    if (get_val(PS4_L2)) {
                        if (event_press(PS4_UP))   fade_delay_duration += 200;
                        if (event_press(PS4_DOWN))  fade_delay_duration -= 200;
                        if (scroll_fired && scroll_repeat_timer >= SCROLL_REPEAT_RATE) { fade_delay_duration += scroll_held * 200; scroll_repeat_timer = 0; }
                    } else {
                        if (event_press(PS4_UP))   fade_delay_duration += 1;
                        if (event_press(PS4_DOWN))  fade_delay_duration -= 1;
                        if (scroll_fired && scroll_repeat_timer >= SCROLL_REPEAT_RATE) { fade_delay_duration += scroll_held; scroll_repeat_timer = 0; }
                    }
                    if (event_press(PS4_UP) || event_press(PS4_DOWN) || (scroll_fired && scroll_repeat_timer == 0 && scroll_held != 0)) {
                        set_pvar(SPVAR_30, fade_delay_duration); combo_run(vibration_valchg); combo_run(flashedit);
                    }
                    if (fade_delay_duration > 6000) fade_delay_duration = 6000;
                    if (fade_delay_duration < 0)    fade_delay_duration = 0;

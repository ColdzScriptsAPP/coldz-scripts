combo turbo_L_combo {
    if (turbo_mode == 0) {
        set_val(PS4_RY, STICK_UP_VALUE + random(random_variation_min, random_variation_max));
    } else {
        set_val(PS4_RY, STICK_DOWN_VALUE + random(random_variation_min, random_variation_max));
    }
    set_val(PS4_RX, random(random_variation_min, random_variation_max));
    wait(turbo_L_timing / 4);
    if (turbo_mode == 0) {
        set_val(PS4_RY, 50 + random(random_hold_variation_min, random_hold_variation_max));
    } else {
        set_val(PS4_RY, -50 + random(random_hold_variation_min, random_hold_variation_max));
    }
    set_val(PS4_RX, random(random_hold_variation_min, random_hold_variation_max));
    wait(turbo_L_tempo / 20);
    if (turbo_mode == 0) {
        set_val(PS4_RY, STICK_DOWN_VALUE + random(random_variation_min, random_variation_max));
    } else {
        set_val(PS4_RY, STICK_UP_VALUE + random(random_variation_min, random_variation_max));
    }
    set_val(PS4_RX, random(random_variation_min, random_variation_max));
    wait(300);
    set_val(PS4_RY, 0);
    set_val(PS4_RX, 0);
}


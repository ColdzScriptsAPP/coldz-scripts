    wait(fade_delay_duration / 20);
    set_val(PS4_RY, 100 + random(random_variation_min, random_variation_max));
    set_val(PS4_RX, -25 + random(random_variation_min, random_variation_max));
    wait(300);
    set_val(PS4_RY, 0);

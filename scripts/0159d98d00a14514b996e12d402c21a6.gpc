                        set_pvar(SPVAR_5, zenColour); combo_run(vibration_valchg);
                    }
                    if (get_val(PS4_L2) && event_press(PS4_DOWN)) {
                        zenColour--;
                        if (zenColour < 0) zenColour = 6;
                        set_pvar(SPVAR_5, zenColour); combo_run(vibration_valchg);
                    }
                }

            }

            if (trans_active) {
                step_transition();
            }

            draw_bubbles();

            set_val(PS4_CROSS,    0);
            set_val(PS4_CIRCLE,   0);
            set_val(PS4_SQUARE,   0);
            set_val(PS4_TRIANGLE, 0);
            set_val(PS4_L1,       0);
            set_val(PS4_R1,       0);
            set_val(PS4_L2,       0);
            set_val(PS4_R2,       0);
            set_val(PS4_L3,       0);
            set_val(PS4_R3,       0);
            set_val(PS4_UP,       0);
            set_val(PS4_DOWN,     0);
            set_val(PS4_LEFT,     0);
            set_val(PS4_RIGHT,    0);
            set_val(PS4_OPTIONS,  0);
            set_val(PS4_LX,       0);
            set_val(PS4_LY,       0);
            set_val(PS4_RX,       0);
            set_val(PS4_RY,       0);

        }

        if (!menu_enabled) {

            if      (zenColour == 0) { set_rgb(255, 0, 0); }
            else if (zenColour == 1) { set_rgb(0, 255, 0); }
            else if (zenColour == 2) { set_rgb(0, 0, 255); }
            else if (zenColour == 3) { set_rgb(0, 255, 255); }
            else if (zenColour == 4) { set_rgb(128, 0, 255); }
            else if (zenColour == 5) { set_rgb(255, 255, 255); }
            else {
                rainbow_timer += get_rtime();
                if (rainbow_timer >= 16) {
                    rainbow_hue++;
                    if (rainbow_hue >= 360) rainbow_hue = 0;
                    rainbow_timer = 0;
                    rainbow_seg = rainbow_hue / 60;
                    rainbow_pos = rainbow_hue % 60;
                    if (rainbow_seg == 0) { rainbow_r = 255;                        rainbow_g = (rainbow_pos * 255) / 59; rainbow_b = 0;                          }
                    else if (rainbow_seg == 1) { rainbow_r = 255 - (rainbow_pos * 255) / 59; rainbow_g = 255;                        rainbow_b = 0;                          }
                    else if (rainbow_seg == 2) { rainbow_r = 0;                          rainbow_g = 255;                        rainbow_b = (rainbow_pos * 255) / 59;   }
                    else if (rainbow_seg == 3) { rainbow_r = 0;                          rainbow_g = 255 - (rainbow_pos * 255) / 59; rainbow_b = 255;                        }
                    else if (rainbow_seg == 4) { rainbow_r = (rainbow_pos * 255) / 59;   rainbow_g = 0;                          rainbow_b = 255;                        }
                    else                       { rainbow_r = 255;                        rainbow_g = 0;                          rainbow_b = 255 - (rainbow_pos * 255) / 59; }
                }
                set_rgb(rainbow_r, rainbow_g, rainbow_b);
            }

            if (square_shooting_in_progress        ||
                combo_running(flick_up_rs_smooth)   || combo_running(flick_up_rs_reversed) ||
                combo_running(noDip_combo)           || combo_running(rs_setshot_flick)     ||
                combo_running(rs_fade_flick)         || combo_running(rs_noDip_flick)       ||
                combo_running(Insta_shot_L)          || combo_running(Insta_shot_R)         ||
                combo_running(New_Insta_shot_smooth) || combo_running(New_Insta_shot_reversed) ||
                combo_running(turbo_L_combo)         || combo_running(turbo_R_combo)) {
                shot_display_active = 1;
                shot_display_timer  = 300;
            } else if (shot_display_active) {
                shot_display_timer -= get_rtime();
                if (shot_display_timer <= 0) {
                    shot_display_active = 0;
                    shot_display_timer  = 0;
                }
            }

            if (shot_display_active) {
                cls_oled(OLED_BLACK);
                draw_jordan_top();
                draw_jordan_bot();
            } else if (saver_on) {
                saver_timer += get_rtime();
                if (saver_timer >= 16) {
                    saver_step();
                    draw_bubbles();
                    saver_timer = 0;
                }
            }

            current_time += get_rtime();

            if (meterDunkActive && get_val(PS4_CIRCLE) && get_val(PS4_R2) && !get_val(PS4_L2)) {
                if (!meterDunkComboRunning) {
                    combo_run(meter_dunk_combo);
                    meterDunkComboRunning   = 1;
                    meterDunkOverrideActive = 1;
                    meterDunkStartTime      = current_time;
                }
            } else {
                if (meterDunkComboRunning && (!get_val(PS4_CIRCLE) || !get_val(PS4_R2) || (current_time - meterDunkStartTime) >= meterDunkDuration)) {
                    combo_stop(meter_dunk_combo);
                    meterDunkComboRunning   = 0;
                    meterDunkOverrideActive = 0;
                }
            }

            if      (remap_square_active == 0) { if (get_val(PS4_L3)) set_val(PS4_SQUARE, 100); }
            else if (remap_square_active == 1) { if (get_val(PS4_R3)) set_val(PS4_SQUARE, 100); }

            if (event_press(PS4_SQUARE) && !(remap_square_active == 0 && get_val(PS4_L3)) && !(remap_square_active == 1 && get_val(PS4_R3))) {
                if (get_val(PS4_R2) > 20) { is_turbo_fade = 1; } else { is_turbo_fade = 0; }
            }

            if (flick_up_shooting_active) {
                if (!(remap_square_active == 0 && get_val(PS4_L3)) && !(remap_square_active == 1 && get_val(PS4_R3)) && get_val(PS4_L2) && get_val(PS4_SQUARE)) {
                    if (!get_val(PS4_R1)) {
                        set_val(PS4_SQUARE, 0);
                        noDip_active = 1;
                        set_val(PS4_RY, STICK_DOWN_VALUE + random(random_variation_min, random_variation_max));
                        set_val(PS4_RX, random(random_variation_min, random_variation_max));
                    }
                }
                if (!(remap_square_active == 0 && get_val(PS4_L3)) && !(remap_square_active == 1 && get_val(PS4_R3)) && get_val(PS4_L2) && event_release(PS4_SQUARE)) {
                    if (noDip_active) { combo_run(noDip_combo); noDip_active = 0; }
                }
            }

            if (flick_up_shooting_active) {
                if (!(remap_square_active == 0 && get_val(PS4_L3)) && !(remap_square_active == 1 && get_val(PS4_R3)) && !get_val(PS4_L2) && get_val(PS4_SQUARE)) {
                    if (!get_val(PS4_R1) && !combo_running(turbo_L_combo) && !combo_running(turbo_R_combo)) {
                        set_val(PS4_SQUARE, 0);
                        square_shooting_in_progress = 1;
                        if (is_turbo_fade) {
                            set_val(PS4_RY, STICK_UP_VALUE + random(random_variation_min, random_variation_max));
                        } else {
                            set_val(PS4_RY, STICK_DOWN_VALUE + random(random_variation_min, random_variation_max));
                        }
                        set_val(PS4_RX, random(random_variation_min, random_variation_max));
                    }
                }
                if (!(remap_square_active == 0 && get_val(PS4_L3)) && !(remap_square_active == 1 && get_val(PS4_R3)) && !get_val(PS4_L2) && event_release(PS4_SQUARE)) {
                    if (square_shooting_in_progress && !combo_running(turbo_L_combo) && !combo_running(turbo_R_combo)) {
                        if (is_turbo_fade) { combo_run(flick_up_rs_reversed); }
                        else                { combo_run(flick_up_rs_smooth);   }
                        square_shooting_in_progress = 0;
                        is_turbo_fade               = 0;
                    }
                }
            }

            if (Insta_shot_active) {
                if ((remap_square_active == 0 && get_val(PS4_R2) && event_press(PS4_R3) && abs(get_val(PS4_LX)) <= 30) ||
                    (remap_square_active == 1 && get_val(PS4_R2) && event_press(PS4_L3) && abs(get_val(PS4_LX)) <= 30)) {
                    combo_run(Insta_shot_L);
                }
            }

            if (New_Insta_shot_active) {
                if ((remap_square_active == 0 && !get_val(PS4_L2) && !get_val(PS4_R2) && event_press(PS4_R3)) ||
                    (remap_square_active == 1 && !get_val(PS4_L2) && !get_val(PS4_R2) && event_press(PS4_L3))) {
                    combo_run(New_Insta_shot_reversed);
                }
            }

            if (get_val(PS4_R2) > 20 && event_press(PS4_R3)) {
                if (get_val(PS4_LX) < -30 && !combo_running(turbo_L_combo) && !combo_running(turbo_R_combo) && !combo_running(Insta_shot_L) && !combo_running(Insta_shot_R)) {
                    combo_run(turbo_L_combo);
                    square_shooting_in_progress = 0;
                    is_turbo_fade               = 0;
                } else if (get_val(PS4_LX) > 30 && !combo_running(turbo_L_combo) && !combo_running(turbo_R_combo) && !combo_running(Insta_shot_L) && !combo_running(Insta_shot_R)) {
                    combo_run(turbo_R_combo);
                    square_shooting_in_progress = 0;
                    is_turbo_fade               = 0;
                }
            }

            if (rs_shooting_active) {
                if (!(get_val(PS4_L2) > 20 && (get_val(PS4_R1) > 20 || get_val(PS4_LEFT) || get_val(PS4_RIGHT) || get_val(PS4_UP) || get_val(PS4_DOWN) || get_val(PS4_OPTIONS)))) {
                    if (abs(get_val(PS4_RY)) > 30 && abs(get_val(PS4_RX)) <= 30) {
                        if (!isHolding) {
                            isHolding               = 1;
                            rs_shooting_in_progress = 1;
                            holdTimer               = 0;
                            if (get_val(PS4_RY) < 0) { rs_is_up = 1; } else { rs_is_up = 0; }
                            if (get_val(PS4_L2) > 20) { noDip_active = 1; } else { noDip_active = 0; }
                        }
                        holdTimer += get_rtime();
                    } else if (abs(get_val(PS4_RY)) <= 30 && abs(get_val(PS4_RX)) <= 30) {
                        if (isHolding) {
                            if (holdTimer > rs_hold_duration) {
                                if (noDip_active)    { combo_run(rs_noDip_flick); }
                                else if (!rs_is_up)  { combo_run(rs_setshot_flick); }
                                else                 { combo_run(rs_fade_flick); }
                            }
                            isHolding               = 0;
                            rs_shooting_in_progress = 0;
                            noDip_active            = 0;
                            holdTimer               = 0;
                        }
                    }
                }
            }

            if (spotTakeMacro && get_val(PS4_CROSS)) {
                combo_run(spot_take_combo);
            }

        }

        if (vibratorActive && !combo_running(vibrator_cycle)) {
            combo_run(vibrator_cycle);
        }

    }

}

function ApplyPreset(idx) {
    if (idx == 0) { preset_val_L = preset_0_L; preset_val_R = preset_0_R; }
    else if (idx == 1) { preset_val_L = preset_1_L; preset_val_R = preset_1_R; }
    else if (idx == 2) { preset_val_L = preset_2_L; preset_val_R = preset_2_R; }
    else               { preset_val_L = preset_3_L; preset_val_R = preset_3_R; }

    if (preset_val_L >= 0) {
        Insta_shot_active      = preset_val_L / 1000000000;
        Insta_shot_duration_L  = (preset_val_L % 1000000000) / 10000;
        Delay_duration_Insta_L = preset_val_L % 10000;
        set_pvar(SPVAR_21, Insta_shot_active);
        set_pvar(SPVAR_22, Insta_shot_duration_L);
        set_pvar(SPVAR_23, Delay_duration_Insta_L);
        Insta_shot_duration_R  = Insta_shot_duration_L;
        Delay_duration_Insta_R = Delay_duration_Insta_L;
    }
    if (preset_val_R >= 0) {
    }
}

combo Movement_Control {
    if (infinite_stamina && ground_stick_active && !meterDunkOverrideActive &&
        !square_shooting_in_progress && !rs_shooting_in_progress && !get_val(PS4_SQUARE) &&
        !combo_running(flick_up_rs_smooth) && !combo_running(flick_up_rs_reversed) &&
        !combo_running(rs_setshot_flick)   && !combo_running(rs_fade_flick) && !combo_running(rs_noDip_flick) &&
        !combo_running(Insta_shot_L)       && !combo_running(Insta_shot_R) &&
        !combo_running(turbo_L_combo)      && !combo_running(turbo_R_combo)) {
        if (abs(get_val(PS4_LX)) > 20 || abs(get_val(PS4_LY)) > 20) {
            set_val(PS4_LX, (get_val(PS4_LX) * ground_control) / 100);
            set_val(PS4_LY, (get_val(PS4_LY) * ground_control) / 100);
        }
        if (abs(get_val(PS4_LX)) < 20 && abs(get_val(PS4_LY)) < 20) {
            set_val(PS4_LX, 0);
            set_val(PS4_LY, 0);
        }
    }
}

combo meter_dunk_combo {
    set_val(PS4_RY, 100);
    set_val(PS4_R2, 100);
    wait(1000);
    set_val(PS4_RY, 0);
    set_val(PS4_R2, 0);
}


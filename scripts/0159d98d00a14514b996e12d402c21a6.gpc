combo flashtog {
    if (!flashtoggle) { set_rgb(255, 0, 0); }
    else              { set_rgb(0, 255, 0); }
    wait(1000);
    set_rgb(0, 0, 255);
}

combo flashedit {
    set_rgb(0, 0, 0);
    wait(150);
    set_rgb(0, 0, 255);
}

combo vibration_on {
    wait(200);
}

combo vibration_off {
    wait(200);
}

combo vibration_valchg {
    wait(60);
}

combo vibrator_cycle {
    set_rumble(RUMBLE_A, 100);
    wait(1000);
}

combo spot_take_combo {
    set_val(PS4_CROSS, 100);
    wait(10);
    set_val(PS4_CROSS, 0);
    wait(10);
    set_val(PS4_CROSS, 100);
    wait(10);
}

function map(val, in_min, in_max, out_min, out_max) {
    return (val - in_min) * (out_max - out_min) / (in_max - in_min) + out_min;
}

function draw_x_graph(value, min_val, max_val, y_pos) {
    graph_width = 100;
    x_start     = (OLED_WIDTH - graph_width) / 2;
    mid_x       = x_start + graph_width / 2;
    bar_pos     = map(value, min_val, max_val, 0, graph_width);
    line_oled(x_start, y_pos, x_start + graph_width, y_pos, 1, OLED_WHITE);
    line_oled(mid_x,   y_pos - 3, mid_x,                  y_pos + 3, 1, OLED_WHITE);
    line_oled(x_start, y_pos - 2, x_start,                y_pos + 2, 1, OLED_WHITE);
    line_oled(x_start + graph_width, y_pos - 2, x_start + graph_width, y_pos + 2, 1, OLED_WHITE);
    rect_oled(x_start, y_pos - 2, bar_pos, 4, 1, OLED_WHITE);
}

function center_x(f_chars, f_font) {
    return (OLED_WIDTH / 2) - ((f_chars * f_font) / 2);
}

function FindDigits(num) {
    logVal = 0;
    do { num /= 10; logVal++; } while (num);
    return logVal;
}

function get_string_length(offset) {
    stringLength = 0;
    while (duint8(offset++)) { stringLength++; }
    return stringLength + 1;
}

function NumberToString(f_val, f_digits) {
    bufferIndex = 1;
    digitIndex  = 10000;
    if (f_val < 0) { putc_oled(bufferIndex, 45); bufferIndex++; f_val = abs(f_val); }
    for (charIndex = 5; charIndex >= 1; charIndex--) {
        if (f_digits >= charIndex) {
            putc_oled(bufferIndex, (f_val / digitIndex) + 48);
            f_val %= digitIndex;
            bufferIndex++;
            if (charIndex == 4) { putc_oled(bufferIndex, 44); bufferIndex++; }
        }
        digitIndex /= 10;
    }
    puts_oled(center_x(bufferIndex - 1, OLED_FONT_MEDIUM_WIDTH) + slide_ox, 28, OLED_FONT_MEDIUM, bufferIndex - 1, OLED_WHITE);
}

function DecimalToString(f_val) {
    whole     = f_val / 20;
    frac      = (f_val % 20) * 5;
    frac_tens = frac / 10;
    frac_ones = frac % 10;
    bufferIndex = 1;
    if (whole >= 100) {
        putc_oled(bufferIndex, (whole / 100) + 48);        bufferIndex++;
        putc_oled(bufferIndex, ((whole / 10) % 10) + 48);  bufferIndex++;
        putc_oled(bufferIndex, (whole % 10) + 48);         bufferIndex++;
    } else if (whole >= 10) {
        putc_oled(bufferIndex, (whole / 10) + 48);         bufferIndex++;
        putc_oled(bufferIndex, (whole % 10) + 48);         bufferIndex++;
    } else {
        putc_oled(bufferIndex, whole + 48);                bufferIndex++;
    }
    putc_oled(bufferIndex, 46);              bufferIndex++;
    putc_oled(bufferIndex, frac_tens + 48);  bufferIndex++;
    putc_oled(bufferIndex, frac_ones + 48);  bufferIndex++;
    puts_oled(center_x(bufferIndex - 1, OLED_FONT_MEDIUM_WIDTH) + slide_ox, 28, OLED_FONT_MEDIUM, bufferIndex - 1, OLED_WHITE);
}

function QuarterToString(f_val) {
    q_whole = f_val / 4;
    q_frac  = (f_val % 4) * 25;
    bufferIndex = 1;
    if (q_whole >= 1000) {
        putc_oled(bufferIndex, (q_whole / 1000) + 48);         bufferIndex++;
        putc_oled(bufferIndex, ((q_whole / 100) % 10) + 48);   bufferIndex++;
        putc_oled(bufferIndex, ((q_whole / 10) % 10) + 48);    bufferIndex++;
        putc_oled(bufferIndex, (q_whole % 10) + 48);           bufferIndex++;
    } else if (q_whole >= 100) {
        putc_oled(bufferIndex, (q_whole / 100) + 48);          bufferIndex++;
        putc_oled(bufferIndex, ((q_whole / 10) % 10) + 48);    bufferIndex++;
        putc_oled(bufferIndex, (q_whole % 10) + 48);           bufferIndex++;
    } else if (q_whole >= 10) {
        putc_oled(bufferIndex, (q_whole / 10) + 48);           bufferIndex++;
        putc_oled(bufferIndex, (q_whole % 10) + 48);           bufferIndex++;
    } else {
        putc_oled(bufferIndex, q_whole + 48);                  bufferIndex++;
    }
    putc_oled(bufferIndex, 46);              bufferIndex++;
    putc_oled(bufferIndex, (q_frac / 10) + 48); bufferIndex++;
    putc_oled(bufferIndex, (q_frac % 10) + 48); bufferIndex++;
    puts_oled(center_x(bufferIndex - 1, OLED_FONT_MEDIUM_WIDTH) + slide_ox, 28, OLED_FONT_MEDIUM, bufferIndex - 1, OLED_WHITE);
}

function saver_step() {
    cls_oled(OLED_BLACK);

    print(sx, sy, OLED_FONT_SMALL, OLED_WHITE, saver_line1[0]);

    line1_w = (get_string_length(saver_line1[0]) - 1) * OLED_FONT_SMALL_WIDTH;
    line2_w = 0;
    line3_w = 0;
    line4_w = 0;

    msg_w = line1_w;

    sx += svx;
    sy += svy;

    if (sx <= 1 || sx >= (OLED_WIDTH - msg_w - 1)) {
        svx = -svx;
    }
    if (sy <= 1 || sy >= (OLED_HEIGHT - 14 - 1)) {
        svy = -svy;
    }
}

function start_transition(dir, new_cat, new_incat, new_catpage) {
    trans_active          = 1;
    trans_dir             = dir;
    trans_x               = 0;
    trans_pending_cat     = new_cat;
    trans_pending_incat   = new_incat;
    trans_pending_catpage = new_catpage;
}

function step_transition() {
    if (!trans_active) { return 0; }

    if (trans_active == 1) {
        trans_x += TRANS_STEP;
        if (trans_x >= 128) {
            trans_x = 128;
            if (trans_pending_cat     >= 0) { cur_cat  = trans_pending_cat;     trans_pending_cat     = -1; }
            if (trans_pending_incat   >= 0) { in_cat   = trans_pending_incat;   trans_pending_incat   = -1; }
            if (trans_pending_catpage >= 0) { cat_page = trans_pending_catpage; trans_pending_catpage = -1; }
            trans_active = 2;
        }
        slide_ox = trans_dir * (0 - trans_x);
    } else {
        trans_x -= TRANS_STEP;
        if (trans_x <= 0) {
            trans_x      = 0;
            trans_active = 0;
        }
        slide_ox = trans_dir * (128 - trans_x);
    }
    return 1;
}

function draw_transition() { return step_transition(); }
function trigger_transition(dir) { }

function draw_bubbles() {
    for (bubble_i = 0; bubble_i < num_bubbles; bubble_i++) {
        bubble_y[bubble_i] -= bubble_speed[bubble_i];
        if (bubble_y[bubble_i] < 0) {
            bubble_y[bubble_i]     = 63;
            bubble_x[bubble_i]     = random(2, 125);
            bubble_speed[bubble_i] = random(1, 2);
            bubble_size[bubble_i]  = random(1, 3);
        }
        if (bubble_size[bubble_i] == 1) {
            pixel_oled(bubble_x[bubble_i], bubble_y[bubble_i], OLED_WHITE);
        } else if (bubble_size[bubble_i] == 2) {
            pixel_oled(bubble_x[bubble_i],     bubble_y[bubble_i] - 1, OLED_WHITE);
            pixel_oled(bubble_x[bubble_i] - 1, bubble_y[bubble_i],     OLED_WHITE);
            pixel_oled(bubble_x[bubble_i] + 1, bubble_y[bubble_i],     OLED_WHITE);
            pixel_oled(bubble_x[bubble_i],     bubble_y[bubble_i] + 1, OLED_WHITE);
        } else {
            pixel_oled(bubble_x[bubble_i],     bubble_y[bubble_i] - 2, OLED_WHITE);
            pixel_oled(bubble_x[bubble_i] - 1, bubble_y[bubble_i] - 1, OLED_WHITE);
            pixel_oled(bubble_x[bubble_i] + 1, bubble_y[bubble_i] - 1, OLED_WHITE);
            pixel_oled(bubble_x[bubble_i] - 2, bubble_y[bubble_i],     OLED_WHITE);
            pixel_oled(bubble_x[bubble_i] + 2, bubble_y[bubble_i],     OLED_WHITE);
            pixel_oled(bubble_x[bubble_i] - 1, bubble_y[bubble_i] + 1, OLED_WHITE);
            pixel_oled(bubble_x[bubble_i] + 1, bubble_y[bubble_i] + 1, OLED_WHITE);
            pixel_oled(bubble_x[bubble_i],     bubble_y[bubble_i] + 2, OLED_WHITE);
        }
    }
}

